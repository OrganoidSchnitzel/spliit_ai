# ─── Spliit PostgreSQL connection ────────────────────────────────────────────
# Host of the Spliit PostgreSQL container (use service name in Docker Compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spliit
DB_USER=postgres
DB_PASSWORD=your_db_password_here
# Set to 'true' when connecting to a TLS-enabled database (e.g., cloud-hosted)
DB_SSL=false
# Only set to 'false' if your DB uses a self-signed certificate; keeps validation ON by default
# DB_SSL_REJECT_UNAUTHORIZED=false

# ─── Ollama (local LLM) ───────────────────────────────────────────────────────
# Base URL of the Ollama service (use container/host name in Docker Compose)
OLLAMA_BASE_URL=http://localhost:11434
# LLM model to use for categorization (must be pulled with `ollama pull <model>`)
OLLAMA_MODEL=llama3.2
# Request timeout in milliseconds
OLLAMA_TIMEOUT_MS=60000

# ─── AI behaviour ─────────────────────────────────────────────────────────────
# Confidence threshold (0–1). Suggestions below this value are NOT auto-applied.
# Lower = more aggressive automation, Higher = more conservative (needs manual review).
CONFIDENCE_THRESHOLD=0.6

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Whether to enable the periodic categorization job (true/false)
SCHEDULER_ENABLED=true
# Standard cron expression for when to run automatically (default: every 15 min)
SCHEDULER_CRON=*/15 * * * *

# ─── Processing ───────────────────────────────────────────────────────────────
# Max expenses to process in a single scheduled run
BATCH_SIZE=10

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

